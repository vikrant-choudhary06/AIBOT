# Telegram API Credentials (get from https://my.telegram.org)
API_ID=123456
API_HASH=abcdef1234567890abcdef1234567890

# Pyrogram String Session (generate using a helper script or client)
SESSION_STRING=your_pyrogram_session_string_here

# Local Ollama AI Setup
OLLAMA_URL=http://127.0.0.1:11434
MODEL_NAME=gemma:2b

# Whitelist and Blacklist of Chats (Comma-separated Telegram Chat/Group/User IDs)
# If WHITELIST_CHATS is empty, the bot listens to all chats (except blacklisted ones).
# Private chats (DMs) are always allowed unless explicitly blacklisted.
WHITELIST_CHATS=
BLACKLIST_CHATS=

# Cooldown and Rate Limiting
# COOLDOWN_SECONDS: Minimum time (in seconds) between AI responses in the same chat.
COOLDOWN_SECONDS=5
# REPLY_CHANCE_GROUP: Probability (0.0 to 1.0) of participating in group discussions without being tagged.
REPLY_CHANCE_GROUP=0.05

# AI Persona & System Prompt
# Customize this to change how the AI acts. The system will dynamically mix this with chat memories and styles.
PERSONALITY_PROMPT="You are a casual human chatter named Nandini. You talk to friends on Telegram. You MUST ALWAYS speak in Hinglish (Hindi written using the English alphabet) like 'kya chal raha hai?', 'kuch nhi yaar', 'bas badiya tum batao', 'ha ha sahi hai'. Keep replies very short, realistic, casual, and human-like (usually 1-2 sentences). Do NOT act like an AI, virtual assistant, or robot. Use normal emojis occasionally. If someone roasts you, roast them back casually. Never start replies with formal greetings or introductory phrases."
